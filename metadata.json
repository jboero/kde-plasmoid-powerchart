{
    "KPlugin": {
        "Id": "org.kde.plasma.batterymonitor-boero",
        "Name": "Battery & Power Graph",
        "Description": "Real-time battery level and power consumption graphing widget with historical data",
        "Icon": "battery-full",
        "EnabledByDefault": true,
        "Authors": [
            {
                "Name": "Johnny",
                "Email": ""
            }
        ],
        "Category": "System Information",
        "License": "MPL-2.0",
        "Version": "1.4.0"
    },
    "KPackageStructure": "Plasma/Applet",
    "X-Plasma-API-Minimum-Version": "6.0",
    "X-Plasma-NotificationArea": "true",
    "X-Plasma-NotificationAreaCategory": "Hardware",
    "X-Plasma-Provides": [
        "org.kde.plasma.battery"
    ]
}
